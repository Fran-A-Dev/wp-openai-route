# OpenAI Configuration
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-your-key-here
OPENAI_MODEL=gpt-4o-mini

# Smart Search AI MCP Configuration
# Your WP Engine Smart Search AI MCP endpoint
SMART_SEARCH_MCP_URL=https://your-mcp-endpoint.run.app/mcp
# Optional: MCP authentication token (if required by your setup)
SMART_SEARCH_MCP_TOKEN=

# WordPress Admin Security
# Generate a secure random token: openssl rand -hex 32
WP_ADMIN_COPILOT_TOKEN=your-secure-token-here
# Your WordPress site origin (must match exactly)
WP_ADMIN_ORIGIN=https://your-wordpress-site.com
